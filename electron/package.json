{
  "name": "ticket-system-electron",
  "version": "0.2.0",
  "private": true,
  "description": "Electron + React клиент Ticket_system",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://127.0.0.1:5173 && cross-env ELECTRON_DEV=1 electron .\"",
    "build": "vite build",
    "start": "npm run build && electron .",
    "electron": "electron ."
  },
  "dependencies": {
    "ag-grid-community": "^32.3.3",
    "ag-grid-react": "^32.3.3",
    "pdfjs-dist": "^4.10.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  }
}
