# ============================================================================
# ПЕРЕМЕННЫЕ ОКРУЖЕНИЯ (скопируйте в .env и заполните реальные значения)
# ============================================================================

# === БЕЗОПАСНОСТЬ ===
# Админ пароль (обязателен для боевого сервера)
ADMIN_PASSWORD=your-secure-password-here-change-this

# API ключ для защиты REST API (обязателен!)
TICKET_API_KEY=your-secret-api-key-here-minimum-32-characters

# === РАЗРАБОТКА ===
# DEBUG режим (False для продакшена)
DEBUG=False

# === API СЕРВЕР ===
# Хост и порт для FastAPI
TICKET_API_HOST=127.0.0.1
TICKET_API_PORT=8765

# Разрешённые источники для CORS (для Electron UI)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# === ЛОГИРОВАНИЕ ===
# Уровень логирования: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# === OCR (опционально) ===
# Путь к Tesseract (только для Windows)
# Linux/Mac: не требуется (установите через apt/brew)
TESSERACT_CMD=/usr/bin/tesseract

# === БАЗА ДАННЫХ ===
# Путь к SQLite базе (обычно не нужно менять)
# DATABASE_PATH=./data/employees.db
